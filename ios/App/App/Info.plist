<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CAPACITOR_DEBUG</key>
	<string>$(CAPACITOR_DEBUG)</string>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
        <string>CortexBuild</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>
	<!-- Camera -->
	<key>NSCameraUsageDescription</key>
	<string>CortexBuild uses the camera to capture site photos, daily report images, and safety incident documentation.</string>
	<!-- Microphone (for voice daily reports) -->
	<key>NSMicrophoneUsageDescription</key>
	<string>CortexBuild uses the microphone to record audio notes for daily site reports.</string>
	<!-- Location when in use (for clock-in geofencing) -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>CortexBuild uses your location to verify you are on-site when clocking in and to record incident locations.</string>
	<!-- Location always (background tracking for safety) -->
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>CortexBuild can use your location in the background to track site attendance and safety compliance.</string>
	<!-- Photo library read (for attaching existing photos) -->
	<key>NSPhotoLibraryUsageDescription</key>
	<string>CortexBuild accesses your photo library to attach existing photos to reports and incidents.</string>
	<!-- Photo library save (for saving captured images) -->
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>CortexBuild saves captured site photos to your photo library.</string>
	<!-- Background modes for push notifications -->
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
		<string>fetch</string>
	</array>
</dict>
</plist>
