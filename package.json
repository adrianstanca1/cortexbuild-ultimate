{
  "name": "cortexbuild-ultimate",
  "private": true,
  "version": "3.0.0",
  "description": "CortexBuild Ultimate — AI-Powered Unified Construction Management Platform for UK Contractors",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "test": "NODE_ENV=test vitest run",
    "test:watch": "NODE_ENV=test vitest",
    "test:coverage": "NODE_ENV=test vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "verify": "./scripts/pre-commit-check.sh",
    "verify:routes": "./scripts/verify-server-routes.sh",
    "verify:all": "./scripts/verify-server-routes.sh && ./scripts/pre-commit-check.sh",
    "precommit": "./scripts/pre-commit-check.sh",
    "check": "npx tsc --noEmit && npm run lint && npm test",
    "prepare": "husky install"
  },
  "dependencies": {
    "@dnd-kit/utilities": "^3.2.2",
    "@sendgrid/mail": "^8.1.6",
    "@tanstack/react-query": "^5.99.0",
    "@types/three": "^0.183.1",
    "autoprefixer": "10.4.20",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^1.8.0",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "prom-client": "^15.1.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router": "^7.14.0",
    "react-router-dom": "^7.14.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "3.4.17",
    "three": "^0.183.2",
    "web-ifc": "^0.0.77",
    "web-ifc-three": "^0.0.126",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "@rolldown/binding-linux-arm64-gnu": "^1.0.0-rc.12"
  },
  "devDependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-react": "^6.0.1",
    "daisyui": "4.12.24",
    "esbuild": "^0.27.7",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "happy-dom": "^20.8.9",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.9",
    "sharp": "^0.34.5",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "bash -c 'npx tsc --noEmit'"
    ],
    "*.{js,jsx}": [
      "eslint --fix"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "web-ifc-three": {
      "three": "^0.183.2"
    }
  }
}
