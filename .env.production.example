# ═══════════════════════════════════════════════════════════════════════════════
# CortexBuild Ultimate - Production Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# 
# SECURITY WARNING: Never commit this file! Add to .gitignore.
# 
# Generate secrets with:
#   - 64 char hex: openssl rand -hex 32
#   - 32 char string: openssl rand -base64 32
#   - UUID: uuidgen
#
# Copy this to .env and fill in your production values
# ═══════════════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────────────
# DATABASE CONFIGURATION
# ───────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection (internal Docker network)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=cortexbuild
DB_USER=cortexbuild
DB_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD

# Full connection string for Prisma/ORM
DATABASE_URL=postgresql://cortexbuild:CHANGE_ME@postgres:5432/cortexbuild?schema=public

# ───────────────────────────────────────────────────────────────────────────────
# AUTHENTICATION & SECURITY
# ───────────────────────────────────────────────────────────────────────────────

# JWT secret for token signing (generate: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_USE_64_CHARACTER_HEX_STRING

# Session secret (generate: openssl rand -hex 32)
SESSION_SECRET=CHANGE_ME_USE_64_CHARACTER_HEX_STRING

# CORS allowed origins (comma-separated, no spaces)
CORS_ORIGIN=https://cortexbuildpro.com,https://www.cortexbuildpro.com

# ───────────────────────────────────────────────────────────────────────────────
# GOOGLE OAUTH CONFIGURATION
# ───────────────────────────────────────────────────────────────────────────────
# Get credentials from: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3001/api/auth/google/callback (dev)
#                          https://your-domain.com/api/auth/google/callback (prod)

GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# ───────────────────────────────────────────────────────────────────────────────
# MICROSOFT OAUTH CONFIGURATION
# ───────────────────────────────────────────────────────────────────────────────
# Get credentials from: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps/ApplicationsListBlade
# Registered app: https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps/CreateApplicationFrameBlade
# Authorized redirect URI: http://localhost:3001/api/auth/microsoft/callback (dev)
#                          https://your-domain.com/api/auth/microsoft/callback (prod)

MICROSOFT_CLIENT_ID=your_microsoft_client_id_here
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret_here
MICROSOFT_CALLBACK_URL=http://localhost:3001/api/auth/microsoft/callback

# Frontend URL for OAuth redirect after successful login
FRONTEND_URL=http://localhost:5173

# ───────────────────────────────────────────────────────────────────────────────
# API SERVER CONFIGURATION
# ───────────────────────────────────────────────────────────────────────────────

# API server port
PORT=3001

# Node environment
NODE_ENV=production

# ───────────────────────────────────────────────────────────────────────────────
# AI / OLLAMA CONFIGURATION
# ───────────────────────────────────────────────────────────────────────────────

# Ollama host (internal Docker network)
OLLAMA_HOST=http://ollama:11434

# Default model for chat/completions
OLLAMA_MODEL=qwen3.5:latest

# Embedding model for RAG/vector search
EMBEDDING_MODEL=nomic-embed-text:latest

# External AI fallback (optional)
# GEMINI_API_KEY=CHANGE_ME_IF_USING
# OPENAI_API_KEY=CHANGE_ME_IF_USING
# ANTHROPIC_API_KEY=CHANGE_ME_IF_USING

# ───────────────────────────────────────────────────────────────────────────────
# EMAIL CONFIGURATION
# ───────────────────────────────────────────────────────────────────────────────

# SMTP settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=CHANGE_ME@example.com
SMTP_PASS=CHANGE_ME_USE_APP_PASSWORD

# Email sender
EMAIL_FROM=noreply@cortexbuildpro.com
EMAIL_NAME=CortexBuild

# ───────────────────────────────────────────────────────────────────────────────
# FILE STORAGE
# ───────────────────────────────────────────────────────────────────────────────

# Upload directory (inside container)
UPLOAD_DIR=/app/uploads

# Max upload size (in bytes, default 100MB)
MAX_UPLOAD_SIZE=104857600

# ───────────────────────────────────────────────────────────────────────────────
# REDIS CONFIGURATION (optional for caching/sessions)
# ───────────────────────────────────────────────────────────────────────────────

REDIS_URL=redis://redis:6379

# ───────────────────────────────────────────────────────────────────────────────
# MONITORING & LOGGING
# ───────────────────────────────────────────────────────────────────────────────

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Enable request logging
LOG_REQUESTS=true

# ───────────────────────────────────────────────────────────────────────────────
# DEPLOYMENT WEBHOOK (optional for CI/CD)
# ───────────────────────────────────────────────────────────────────────────────

# GitHub deploy webhook secret (generate: openssl rand -hex 32)
DEPLOY_SECRET=CHANGE_ME_USE_64_CHARACTER_HEX_STRING

# ───────────────────────────────────────────────────────────────────────────────
# FEATURE FLAGS
# ───────────────────────────────────────────────────────────────────────────────

FEATURE_AI_AGENTS=true
FEATURE_RAG_SEARCH=true
FEATURE_WEBSOCKET=true
FEATURE_FILE_UPLOAD=true
FEATURE_EMAIL=true

# ───────────────────────────────────────────────────────────────────────────────
# PRODUCTION-SPECIFIC
# ───────────────────────────────────────────────────────────────────────────────

# Trust proxy (set to true behind nginx/reverse proxy)
TRUST_PROXY=true

# Cookie secure flag (true for HTTPS)
COOKIE_SECURE=true

# Rate limiting (requests per minute)
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
