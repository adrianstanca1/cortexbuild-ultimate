# ═══════════════════════════════════════════════════════════════════════════════
# CortexBuild Ultimate - Production Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
#
# SECURITY: Never commit this file! Add to .gitignore.
#
# Generate secrets with:
#   openssl rand -hex 32
#
# Copy this to .env and fill in your production values
# ═══════════════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────────────
# DATABASE CONFIGURATION
# ───────────────────────────────────────────────────────────────────────────────

DB_HOST=postgres
DB_PORT=5432
DB_NAME=cortexbuild
DB_USER=cortexbuild
DB_PASSWORD=GENERATE_STRONG_PASSWORD

# Full connection string for Drizzle/Prisma
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@postgres:5432/${DB_NAME}?schema=public

# ───────────────────────────────────────────────────────────────────────────────
# AUTHENTICATION & SECURITY
# ───────────────────────────────────────────────────────────────────────────────

# JWT secret for token signing (64 char hex = 32 bytes)
# Generate: openssl rand -hex 32
JWT_SECRET=GENERATE_64_CHAR_HEX

# Session secret (64 char hex = 32 bytes)
SESSION_SECRET=GENERATE_64_CHAR_HEX

# CORS allowed origins (comma-separated, no spaces)
CORS_ORIGIN=https://cortexbuildpro.com,https://www.cortexbuildpro.com

# ───────────────────────────────────────────────────────────────────────────────
# REDIS
# ───────────────────────────────────────────────────────────────────────────────

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ───────────────────────────────────────────────────────────────────────────────
# API SERVER
# ───────────────────────────────────────────────────────────────────────────────

PORT=3001
NODE_ENV=production

# ───────────────────────────────────────────────────────────────────────────────
# AI / OLLAMA
# ───────────────────────────────────────────────────────────────────────────────

OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=qwen3.5:latest
EMBEDDING_MODEL=nomic-embed-text:latest

# ───────────────────────────────────────────────────────────────────────────────
# GOOGLE OAUTH (optional)
# ───────────────────────────────────────────────────────────────────────────────
# In Google Cloud Console → Credentials → OAuth client, add this exact URL under
# "Authorized redirect URIs" (same for Microsoft Entra redirect URI list).

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://www.cortexbuildpro.com/api/auth/google/callback

# ───────────────────────────────────────────────────────────────────────────────
# MICROSOFT OAUTH (optional)
# ───────────────────────────────────────────────────────────────────────────────

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common
MICROSOFT_CALLBACK_URL=https://www.cortexbuildpro.com/api/auth/microsoft/callback

FRONTEND_URL=https://www.cortexbuildpro.com

# ───────────────────────────────────────────────────────────────────────────────
# DEPLOYMENT & MONITORING
# ───────────────────────────────────────────────────────────────────────────────

DEPLOY_SECRET=GENERATE_64_CHAR_HEX
DEPLOY_WEBHOOK_URL=

# ───────────────────────────────────────────────────────────────────────────────
# UPLOAD / FILE CONFIGURATION
# ───────────────────────────────────────────────────────────────────────────────

UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE=104857600

# ───────────────────────────────────────────────────────────────────────────────
# PRODUCTION SETTINGS
# ───────────────────────────────────────────────────────────────────────────────

TRUST_PROXY=true
COOKIE_SECURE=true
LOG_LEVEL=info

# ───────────────────────────────────────────────────────────────────────────────
# FEATURE FLAGS
# ───────────────────────────────────────────────────────────────────────────────

FEATURE_AI_AGENTS=true
FEATURE_RAG_SEARCH=true
FEATURE_WEBSOCKET=true
FEATURE_FILE_UPLOAD=true
FEATURE_EMAIL=true

# ───────────────────────────────────────────────────────────────────────────────
# EMAIL (optional - for notifications)
# ───────────────────────────────────────────────────────────────────────────────

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@cortexbuildpro.com