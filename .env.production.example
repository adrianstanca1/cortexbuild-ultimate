# ═══════════════════════════════════════════════════════════════════════════════
# CortexBuild Ultimate - Production Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
#
# SECURITY WARNING: Never commit this file! Add to .gitignore.
#
# Generate secrets with:
#   openssl rand -hex 32
#
# Copy this to .env and fill in your production values
# ═══════════════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────────────
# DATABASE CONFIGURATION
# ───────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection (Docker network hostnames)
DB_HOST=cortexbuild-db
DB_PORT=5432
DB_NAME=cortexbuild
DB_USER=cortexbuild
DB_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD

# ───────────────────────────────────────────────────────────────────────────────
# AUTHENTICATION & SECURITY
# ───────────────────────────────────────────────────────────────────────────────

# JWT secret for token signing (generate: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_USE_64_CHARACTER_HEX_STRING

# Session secret (generate: openssl rand -hex 32)
SESSION_SECRET=CHANGE_ME_USE_64_CHARACTER_HEX_STRING

# CORS allowed origins (comma-separated, no spaces)
CORS_ORIGIN=https://cortexbuildpro.com,https://www.cortexbuildpro.com

# ───────────────────────────────────────────────────────────────────────────────
# GOOGLE OAUTH (optional)
# ───────────────────────────────────────────────────────────────────────────────

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# ───────────────────────────────────────────────────────────────────────────────
# MICROSOFT OAUTH (optional)
# ───────────────────────────────────────────────────────────────────────────────

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_CALLBACK_URL=https://www.cortexbuildpro.com/api/auth/microsoft/callback

# Frontend URL for OAuth redirect
FRONTEND_URL=https://www.cortexbuildpro.com

# ───────────────────────────────────────────────────────────────────────────────
# API SERVER
# ───────────────────────────────────────────────────────────────────────────────

PORT=3001
NODE_ENV=production

# ───────────────────────────────────────────────────────────────────────────────
# AI / OLLAMA
# ───────────────────────────────────────────────────────────────────────────────

OLLAMA_HOST=http://cortexbuild-ollama:11434
OLLAMA_MODEL=qwen3.5:latest
EMBEDDING_MODEL=nomic-embed-text:latest

# ───────────────────────────────────────────────────────────────────────────────
# REDIS (Docker network)
# ───────────────────────────────────────────────────────────────────────────────

REDIS_HOST=cortexbuild-redis
REDIS_PORT=6379

# ───────────────────────────────────────────────────────────────────────────────
# DEPLOYMENT WEBHOOK
# ───────────────────────────────────────────────────────────────────────────────

DEPLOY_SECRET=CHANGE_ME_USE_64_CHARACTER_HEX_STRING

# ───────────────────────────────────────────────────────────────────────────────
# PRODUCTION-SPECIFIC
# ───────────────────────────────────────────────────────────────────────────────

TRUST_PROXY=true
COOKIE_SECURE=true