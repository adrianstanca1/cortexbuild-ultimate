{
  "name": "Financial Agent",
  "version": "1.0.0",
  "description": "Autonomous AI agent for budget tracking, cost forecasting, and financial compliance",
  "type": "financial-analyst",
  "enabled": true,
  "autoTrigger": true,
  "triggerConditions": {
    "events": ["costItem.created", "budgetLine.updated", "changeOrder.approved", "progressClaim.submitted"],
    "schedule": "0 8 * * 1",
    "thresholds": {
      "budgetVariance": 10,
      "costOverrun": 5,
      "unapprovedChanges": 3
    }
  },
  "capabilities": [
    "budget-tracking",
    "cost-forecasting",
    "cash-flow-analysis",
    "variance-analysis",
    "change-order-impact",
    "payment-application-review"
  ],
  "tools": [
    "prisma-query",
    "ai-completion",
    "spreadsheet-generator",
    "report-generator",
    "notification-sender"
  ],
  "permissions": {
    "read": ["CostItem", "BudgetLine", "ChangeOrder", "ProgressClaim", "ForecastEntry", "Project"],
    "write": ["FinancialReport", "BudgetAlert", "Forecast"],
    "execute": ["Workflow", "AICompletion"]
  },
  "outputChannels": ["dashboard", "email", "executive-report"],
  "escalationRules": {
    "criticalOverrun": ["executive-notification", "finance-review"],
    "budgetExhausted": ["change-order-required", "work-authorization-hold"],
    "paymentDelay": ["client-notification", "legal-review"]
  },
  "model": {
    "provider": "openai",
    "name": "gpt-4-turbo-preview",
    "temperature": 0.2,
    "maxTokens": 4096
  },
  "metrics": {
    "trackForecastAccuracy": true,
    "measureBudgetHealth": true,
    "predictCashFlow": true
  }
}
