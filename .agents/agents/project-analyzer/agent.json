{
  "name": "Project Analysis Agent",
  "version": "1.0.0",
  "description": "Autonomous AI agent for construction project health analysis, timeline prediction, and risk assessment",
  "type": "construction-analyst",
  "enabled": true,
  "autoTrigger": true,
  "triggerConditions": {
    "events": ["project.created", "project.updated", "milestone.completed", "task.overdue"],
    "schedule": "0 9 * * *",
    "thresholds": {
      "progressVariance": 15,
      "budgetVariance": 10,
      "scheduleVariance": 7
    }
  },
  "capabilities": [
    "timeline-prediction",
    "cost-prediction",
    "risk-assessment",
    "critical-path-analysis",
    "resource-optimization",
    "stakeholder-reporting"
  ],
  "tools": [
    "prisma-query",
    "ai-completion",
    "report-generator",
    "notification-sender",
    "dashboard-updater"
  ],
  "permissions": {
    "read": ["Project", "Task", "Milestone", "CostItem", "BudgetLine", "DailyLog", "WeatherLog"],
    "write": ["Notification", "Report", "DashboardWidget"],
    "execute": ["Workflow", "AICompletion"]
  },
  "outputChannels": ["dashboard", "email", "slack", "webhook"],
  "escalationRules": {
    "criticalRisk": ["immediate-notification", "executive-escalation"],
    "budgetOverrun": ["finance-review", "change-order-suggestion"],
    "scheduleDelay": ["resource-reallocation", "client-notification"]
  },
  "model": {
    "provider": "openai",
    "name": "gpt-4-turbo-preview",
    "temperature": 0.3,
    "maxTokens": 4096
  },
  "metrics": {
    "trackAccuracy": true,
    "benchmarkPredictions": true,
    "learningEnabled": true
  }
}
