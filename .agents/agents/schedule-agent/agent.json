{
  "name": "Schedule Agent",
  "version": "1.0.0",
  "description": "Autonomous AI agent for schedule optimization, critical path analysis, and timeline management",
  "type": "schedule-analyst",
  "enabled": true,
  "autoTrigger": true,
  "triggerConditions": {
    "events": ["task.overdue", "milestone.missed", "dependency.blocked", "project.phase_changed"],
    "schedule": "0 7 * * *",
    "thresholds": {
      "scheduleSlip": 5,
      "criticalTasks": 3,
      "blockedDependencies": 2
    }
  },
  "capabilities": [
    "critical-path-analysis",
    "schedule-optimization",
    "dependency-tracking",
    "delay-impact-analysis",
    "resource-leveling",
    "what-if-scenarios"
  ],
  "tools": [
    "prisma-query",
    "ai-completion",
    "gantt-generator",
    "schedule-simulator",
    "notification-sender"
  ],
  "permissions": {
    "read": ["Task", "Milestone", "WorkPackage", "Project", "TimeEntry", "DailyLog"],
    "write": ["ScheduleReport", "DelayNotice", "TaskRecommendation"],
    "execute": ["Workflow", "ScheduleRecalculate"]
  },
  "outputChannels": ["dashboard", "email", "project-chat"],
  "escalationRules": {
    "criticalDelay": ["executive-escalation", "client-notification"],
    "milestoneMiss": ["recovery-plan-required", "resource-reallocation"],
    "dependencyBlock": ["immediate-resolution", "workaround-suggestion"]
  },
  "model": {
    "provider": "openai",
    "name": "gpt-4-turbo-preview",
    "temperature": 0.3,
    "maxTokens": 4096
  },
  "metrics": {
    "trackScheduleAccuracy": true,
    "measureDelayImpact": true,
    "predictCompletionDate": true
  }
}
