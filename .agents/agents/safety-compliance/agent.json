{
  "name": "Safety Compliance Agent",
  "version": "1.0.0",
  "description": "Autonomous AI agent for safety monitoring, incident prevention, and compliance enforcement",
  "type": "safety-compliance",
  "enabled": true,
  "autoTrigger": true,
  "triggerConditions": {
    "events": ["safetyIncident.created", "permitToWork.expired", "riskAssessment.overdue", "toolboxTalk.missed"],
    "schedule": "0 7 * * *",
    "thresholds": {
      "incidentRate": 5,
      "openPermits": 10,
      "overdueAssessments": 3
    }
  },
  "capabilities": [
    "incident-analysis",
    "pattern-detection",
    "compliance-monitoring",
    "risk-prediction",
    "permit-tracking",
    "training-verification"
  ],
  "tools": [
    "prisma-query",
    "ai-completion",
    "notification-sender",
    "report-generator",
    "image-analysis"
  ],
  "permissions": {
    "read": ["SafetyIncident", "PermitToWork", "RiskAssessment", "ToolboxTalk", "DailyLog", "User"],
    "write": ["Notification", "SafetyReport", "ComplianceAlert"],
    "execute": ["Workflow", "Escalation"]
  },
  "outputChannels": ["dashboard", "email", "sms", "slack"],
  "escalationRules": {
    "fatality": ["immediate-executive", "authority-notification", "work-stoppage"],
    "criticalIncident": ["safety-manager", "project-hold"],
    "permitExpired": ["work-stoppage", "supervisor-notification"],
    "complianceGap": ["safety-coordinator", "corrective-action"]
  },
  "model": {
    "provider": "claude",
    "name": "claude-3-sonnet-20240229",
    "temperature": 0.4,
    "maxTokens": 4096
  },
  "metrics": {
    "trackIncidentTrends": true,
    "measureCompliance": true,
    "predictHighRiskActivities": true
  }
}
