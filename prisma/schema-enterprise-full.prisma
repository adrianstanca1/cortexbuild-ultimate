// CortexBuild Ultimate - Enterprise Prisma Schema v3.0
// Complete construction industry SaaS - 85+ models
// Deployed on VPS with Local LLM (Ollama)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// CORE ENUMS (50+ types)
// ============================================

enum UserRole {
  SUPER_ADMIN
  COMPANY_OWNER
  ADMIN
  PROJECT_MANAGER
  FIELD_WORKER
  VIEWER
}

enum PlanType {
  FREE
  STARTER
  PRO
  ENTERPRISE
  ULTIMATE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  INCOMPLETE
  INCOMPLETE_EXPIRED
  PAST_DUE
  UNPAID
  PAUSED
  CANCELED
}

enum ApiProvider {
  OPENAI
  GEMINI
  CLAUDE
  OLLAMA
  LOCAL
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
  ARCHIVED
}

enum ProjectPhase {
  PRECONSTRUCTION
  FOUNDATION
  STRUCTURAL
  ENVELOPE
  INTERIORS
  MEP
  FINISHES
  COMMISSIONING
  CLOSEOUT
}

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  BLOCKED
  REVIEW
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum CostCategory {
  LABOR
  MATERIALS
  EQUIPMENT
  SUBCONTRACTOR
  PERMITS
  INSURANCE
  UTILITIES
  OVERHEAD
  CONTINGENCY
  OTHER
}

enum CostStatus {
  ESTIMATED
  COMMITTED
  ACTUAL
  INVOICED
  PAID
}

enum ChangeOrderStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  IMPLEMENTED
}

enum RFIStatus {
  OPEN
  PENDING
  ANSWERED
  CLOSED
  ON_HOLD
}

enum RFIPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum SubmittalStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  APPROVED_AS_NOTED
  REJECTED
  REVISED
  CANCELLED
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
  FATALITY
}

enum IncidentStatus {
  REPORTED
  UNDER_INVESTIGATION
  CLOSED
  ESCALATED
}

enum InspectionStatus {
  SCHEDULED
  IN_PROGRESS
  PASSED
  FAILED
  CONDITIONAL
  CANCELLED
}

enum DefectStatus {
  IDENTIFIED
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  VERIFIED
  CLOSED
  REJECTED
}

enum DefectPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MilestoneStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  DELAYED
  AT_RISK
}

enum TimeEntryStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  PROCESSED
}

enum ClaimStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  PARTIALLY_APPROVED
  REJECTED
  PAID
  RETAINED
}

enum WorkflowStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  REVISED
  CANCELLED
  ESCALATED
}

enum NotificationStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  VIEW
  EXPORT
  IMPORT
  LOGIN
  LOGOUT
  PASSWORD_CHANGE
  PERMISSION_CHANGE
  ROLE_CHANGE
  CONFIG_CHANGE
  INTEGRATION_SYNC
  WORKFLOW_EXECUTE
  APPROVAL_REQUEST
  APPROVAL_DECISION
  CUSTOM
}

enum StorageProvider {
  LOCAL
  AWS_S3
  GOOGLE_CLOUD
  AZURE_BLOB
  SUPABASE
  IPFS
}

enum JobStatus {
  PENDING
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
  RETRYING
}

enum JobType {
  REPORT_GENERATION
  DOCUMENT_PROCESSING
  AI_PROCESSING
  DATA_SYNC
  NOTIFICATION_SEND
  BACKUP
  IMPORT
  EXPORT
  WORKFLOW_EXECUTION
  INTEGRATION_SYNC
  CUSTOM
}

enum EquipmentType {
  OWNED
  RENTED
  LEASED
  SUBCONTRACTOR
}

enum EquipmentStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
  RETIRED
}

enum MaterialType {
  CONSUMABLE
  DURABLE
  HAZARDOUS
  SPECIALTY
}

enum MaterialStatus {
  IN_STOCK
  ORDERED
  RESERVED
  DEPLETED
}

enum DocumentType {
  GENERAL
  CONTRACT
  SPECIFICATION
  DRAWING
  MANUAL
  CERTIFICATE
  PERMIT
  INSPECTION
}

enum DrawingDiscipline {
  ARCHITECTURAL
  STRUCTURAL
  MEP
  CIVIL
  LANDSCAPE
  INTERIOR
  FIRE_PROTECTION
}

enum PermitType {
  BUILDING
  ELECTRICAL
  PLUMBING
  MECHANICAL
  FIRE
  ENVIRONMENTAL
  ZONING
}

enum WeatherCondition {
  CLEAR
  CLOUDY
  RAIN
  SNOW
  FOG
  WIND
  STORM
  EXTREME_HEAT
  EXTREME_COLD
}

// ============================================
// ORGANIZATION & TENANCY
// ============================================

model Organization {
  id                   String           @id @default(cuid())
  name                 String
  slug                 String           @unique
  legalName            String?
  taxId                String?
  industry             String           @default("Construction")
  companySize          String?
  website              String?
  logoUrl              String?
  primaryColor         String           @default("#2563EB")
  secondaryColor       String           @default("#7C3AED")
  
  settings             Json             @default("{}")
  entitlements         Json             @default("{}")
  integrationConfigs   Json             @default("{}")
  branding             Json             @default("{}")
  
  maxUsers             Int              @default(10)
  maxProjects          Int              @default(50)
  maxStorageGb         Float            @default(10)
  maxApiCalls          BigInt           @default(100000)
  
  plan                 PlanType         @default(STARTER)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  subscriptionStatus   SubscriptionStatus @default(ACTIVE)
  trialEndsAt          DateTime?
  subscriptionEndsAt   DateTime?
  
  storageUsedBytes     BigInt           @default(0)
  apiCallsThisMonth    BigInt           @default(0)
  lastApiReset         DateTime         @default(now())
  
  isActive             Boolean          @default(true)
  isSuspended          Boolean          @default(false)
  suspendedReason      String?          @db.Text
  
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  deletedAt            DateTime?
  
  users                User[]
  companies            Company[]
  apiKeys              ApiKey[]
  webhooks             Webhook[]
  auditLogs            AuditLog[]
  invitations          Invitation[]
  workflows            Workflow[]
  aiModelConfigs       AiModelConfig[]
  integrations         Integration[]
  notifications        Notification[]
  storages             Storage[]
  jobs                 Job[]
  analytics            Analytics[]
  reports              Report[]
  
  @@index([slug])
  @@index([plan])
  @@index([isActive])
}

model Company {
  id              String         @id @default(cuid())
  organizationId  String
  organization    Organization   @relation(fields: [organizationId], references: [id])
  name            String
  address         String?
  city            String?
  state           String?
  country         String?
  postalCode      String?
  phone           String?
  email           String?
  website         String?
  logoUrl         String?
  licenseNumber   String?
  insuranceExpiry DateTime?
  
  settings        Json           @default("{}")
  metadata        Json           @default("{}")
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  users           User[]
  projects        Project[]
  invitations     Invitation[]
  tasks           Task[]
  costItems       CostItem[]
  budgetLines     BudgetLine[]
  changeOrders    ChangeOrder[]
  rfis            RFI[]
  submittals      Submittal[]
  safetyIncidents SafetyIncident[]
  qualityChecks   QualityCheck[]
  toolboxTalks    ToolboxTalk[]
  riskAssessments RiskAssessment[]
  permitsToWork   PermitToWork[]
  equipment       Equipment[]
  materials       Material[]
  permits         Permit[]
  drawings        Drawing[]
  documents       Document[]
  weatherLogs     WeatherLog[]
  dailyLogs       DailyLog[]
  siteDiaries     SiteDiary[]
  progressClaims  ProgressClaim[]
  payrollPeriods  PayrollPeriod[]
  
  @@index([organizationId])
  @@index([name])
}

// ============================================
// USER MANAGEMENT & AUTH
// ============================================

model User {
  id              String         @id @default(cuid())
  email           String         @unique
  emailVerified   DateTime?
  passwordHash    String?
  firstName       String
  lastName        String
  fullName        String         @db.Text
  avatarUrl       String?
  phone           String?
  jobTitle        String?
  department      String?
  employeeId      String?
  
  role            UserRole       @default(FIELD_WORKER)
  permissions     Json           @default("[]")
  
  companyId       String?
  company         Company?       @relation(fields: [companyId], references: [id])
  organizationId  String
  organization    Organization   @relation(fields: [organizationId], references: [id])
  
  isActive        Boolean        @default(true)
  isOnboarded     Boolean        @default(false)
  lastLoginAt     DateTime?
  lastActiveAt    DateTime?
  
  preferences     Json           @default("{}")
  timezone        String         @default("UTC")
  locale          String         @default("en-US")
  theme           String         @default("system")
  
  mfaEnabled      Boolean        @default(false)
  mfaSecret       String?
  mfaBackupCodes  String[]       @default([])
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?
  
  projectMemberships    ProjectMember[]
  assignedTasks         Task[]          @relation("TaskAssignee")
  reportedTasks         Task[]          @relation("TaskReporter")
  createdTasks          Task[]          @relation("TaskCreator")
  timeEntries           TimeEntry[]     @relation("TimeEntryUser")
  dailyLogs             DailyLog[]      @relation("DailyLogCreator")
  rfis                  RFI[]           @relation("RFIRequester")
  assignedRfis          RFI[]           @relation("RFIAssignee")
  submittals            Submittal[]     @relation("SubmittalSubmitter")
  assignedSubmittals    Submittal[]     @relation("SubmittalAssignee")
  safetyIncidents       SafetyIncident[] @relation("IncidentReporter")
  investigatedIncidents SafetyIncident[] @relation("IncidentInvestigator")
  qualityChecks         QualityCheck[]  @relation("QualityInspector")
  toolboxTalks          ToolboxTalk[]   @relation("ToolboxTalkCreator")
  presentedToolboxTalks ToolboxTalk[]   @relation("ToolboxTalkPresenter")
  riskAssessments       RiskAssessment[] @relation("RiskAssessor")
  reviewedRiskAssessments RiskAssessment[] @relation("RiskReviewer")
  approvedRiskAssessments RiskAssessment[] @relation("RiskApprover")
  permitsToWork         PermitToWork[]  @relation("PermitRequester")
  approvedPermits       PermitToWork[]  @relation("PermitApprover")
  supervisedPermits     PermitToWork[]  @relation("PermitSupervisor")
  defects               Defect[]        @relation("DefectIdentifier")
  assignedDefects       Defect[]        @relation("DefectAssignee")
  milestones            Milestone[]     @relation("MilestoneCreator")
  costItems             CostItem[]      @relation("CostItemCreator")
  budgetLines           BudgetLine[]    @relation("BudgetLineCreator")
  changeOrders          ChangeOrder[]   @relation("ChangeOrderCreator")
  approvedChangeOrders  ChangeOrder[]   @relation("ChangeOrderApprover")
  progressClaims        ProgressClaim[] @relation("ClaimSubmitter")
  approvedClaims        ProgressClaim[] @relation("ClaimApprover")
  weatherLogs           WeatherLog[]    @relation("WeatherLogRecorder")
  siteDiaries           SiteDiary[]     @relation("SiteDiaryAuthor")
  equipment             Equipment[]     @relation("EquipmentAssignee")
  materials             Material[]      @relation("MaterialCreator")
  permits               Permit[]        @relation("PermitCreator")
  drawings              Drawing[]       @relation("DrawingUploader")
  documents             Document[]      @relation("DocumentUploader")
  workflows             Workflow[]      @relation("WorkflowCreator")
  apiKeys               ApiKey[]
  webhooks              Webhook[]
  auditLogs             AuditLog[]
  invitations           Invitation[]    @relation("InvitationInviter")
  sessions              Session[]
  accounts              Account[]
  notifications         Notification[]  @relation("NotificationRecipient")
  actorNotifications    Notification[]  @relation("NotificationActor")
  sentCommunications    Communication[] @relation("CommunicationSender")
  approvals             Approval[]      @relation("ApprovalApprover")
  requestedApprovals    Approval[]      @relation("ApprovalRequester")
  delegatedApprovals    Approval[]      @relation("ApprovalDelegate")
  escalatedApprovals    Approval[]      @relation("ApprovalEscalated")
  managedProjects       Project[]       @relation("managedProjects")
  timeEntryApprovals    TimeEntry[]     @relation("TimeEntryApprover")
  rfiAttachments        RFIAttachment[]
  submittalAttachments  SubmittalAttachment[]
  incidentPhotos        IncidentPhoto[]
  incidentDocuments     IncidentDocument[]
  defectPhotos          DefectPhoto[]
  qualityPhotos         QualityPhoto[]
  qualityDocuments      QualityDocument[]
  equipmentLogs         EquipmentLog[]
  equipmentMaintenances EquipmentMaintenance[]
  materialTransactions  MaterialTransaction[]
  documentVersions      DocumentVersion[]
  permitExtensions      PermitExtension[]
  permitChecks          PermitCheck[]
  workflowExecutions    WorkflowExecution[]
  storages              Storage[]
  analytics             Analytics[]
  reports               Report[]
  
  @@index([email])
  @@index([companyId])
  @@index([organizationId])
  @@index([role])
  @@index([isActive])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime
  createdAt    DateTime @default(now())
  ipAddress    String?
  userAgent    String?
  
  @@index([userId])
  @@index([expires])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  
  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Invitation {
  id             String         @id @default(cuid())
  email          String
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id])
  companyId      String?
  company        Company?       @relation(fields: [companyId], references: [id])
  role           UserRole       @default(FIELD_WORKER)
  permissions    Json           @default("[]")
  invitedBy      String
  invitedById    String
  invitedByUser  User           @relation(fields: [invitedById], references: [id])
  status         String         @default("pending")
  token          String         @unique
  expiresAt      DateTime
  acceptedAt     DateTime?
  declinedAt     DateTime?
  declinedReason String?        @db.Text
  metadata       Json           @default("{}")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  
  @@index([email])
  @@index([organizationId])
  @@index([status])
  @@index([token])
}

// ============================================
// AI CONFIGURATION (Local LLM + Cloud)
// ============================================

model AiModelConfig {
  id              String         @id @default(cuid())
  organizationId  String
  organization    Organization   @relation(fields: [organizationId], references: [id])
  
  provider        ApiProvider    @default(OLLAMA)
  model           String         @default("llama3.1:8b")
  tier            String         @default("STANDARD")
  
  credentials     Json           @default("{}")
  apiEndpoint     String         @default("http://localhost:11434")
  apiVersion      String?
  
  temperature     Float          @default(0.7)
  maxTokens       Int            @default(4096)
  topP            Float          @default(1)
  
  visionEnabled   Boolean        @default(false)
  streaming       Boolean        @default(true)
  
  requestsPerMinute Int          @default(60)
  requestsPerHour   Int          @default(1000)
  
  totalRequests   BigInt         @default(0)
  totalTokens     BigInt         @default(0)
  lastRequestAt   DateTime?
  
  isActive        Boolean        @default(true)
  isDefault       Boolean        @default(true)
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  @@index([organizationId])
  @@index([provider])
  @@index([isActive])
}

// ============================================
// PROJECT MANAGEMENT
// ============================================

model Project {
  id              String         @id @default(cuid())
  name            String
  description     String?        @db.Text
  code            String         @unique
  type            String         @default("Commercial")
  sector          String         @default("Building")
  deliveryMethod  String?
  
  address         String?
  city            String?
  state           String?
  country         String         @default("USA")
  postalCode      String?
  latitude        Float?
  longitude       Float?
  
  status          ProjectStatus  @default(PLANNING)
  phase           ProjectPhase   @default(PRECONSTRUCTION)
  startDate       DateTime?
  endDate         DateTime?
  actualStartDate DateTime?
  actualEndDate   DateTime?
  
  budget          Float          @default(0)
  spent           Float          @default(0)
  forecast        Float          @default(0)
  currency        String         @default("USD")
  
  progress        Int            @default(0)
  progressNote    String?        @db.Text
  lastProgressUpdate DateTime?
  
  companyId       String
  company         Company        @relation(fields: [companyId], references: [id])
  projectManagerId String?
  projectManager  User?          @relation("ProjectManager", fields: [projectManagerId], references: [id])
  
  tags            String[]       @default([])
  customFields    Json           @default("{}")
  metadata        Json           @default("{}")
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?
  
  tasks           Task[]
  rfis            RFI[]
  submittals      Submittal[]
  dailyLogs       DailyLog[]
  safetyIncidents SafetyIncident[]
  equipment       Equipment[]
  materials       Material[]
  permits         Permit[]
  drawings        Drawing[]
  documents       Document[]
  milestones      Milestone[]
  costItems       CostItem[]
  budgetLines     BudgetLine[]
  changeOrders    ChangeOrder[]
  timeEntries     TimeEntry[]
  qualityChecks   QualityCheck[]
  defects         Defect[]
  progressClaims  ProgressClaim[]
  weatherLogs     WeatherLog[]
  siteDiaries     SiteDiary[]
  toolboxTalks    ToolboxTalk[]
  riskAssessments RiskAssessment[]
  permitsToWork   PermitToWork[]
  members         ProjectMember[]
  workflows       Workflow[]
  
  @@index([companyId])
  @@index([status])
  @@index([phase])
  @@index([code])
}

model ProjectMember {
  id          String         @id @default(cuid())
  projectId   String
  project     Project        @relation(fields: [projectId], references: [id])
  userId      String
  user        User           @relation(fields: [userId], references: [id])
  
  role        String         @default("member")
  permissions Json           @default("{}")
  joinedAt    DateTime       @default(now())
  invitedBy   String?
  
  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

// ============================================
// TASK & WORK PACKAGES
// ============================================

model Task {
  id              String         @id @default(cuid())
  title           String
  description     String?        @db.Text
  code            String         @unique
  type            String         @default("general")
  category        String?
  
  status          TaskStatus     @default(NOT_STARTED)
  priority        TaskPriority   @default(MEDIUM)
  
  parentTaskId    String?
  parentTask      Task?          @relation("TaskHierarchy", fields: [parentTaskId], references: [id])
  subtasks        Task[]         @relation("TaskHierarchy")
  
  workPackageId   String?
  workPackage     WorkPackage?   @relation(fields: [workPackageId], references: [id])
  
  assigneeId      String?
  assignee        User?          @relation("TaskAssignee", fields: [assigneeId], references: [id])
  reporterId      String?
  reporter        User?          @relation("TaskReporter", fields: [reporterId], references: [id])
  createdById     String
  createdBy       User           @relation("TaskCreator", fields: [createdById], references: [id])
  
  projectId       String
  project         Project        @relation(fields: [projectId], references: [id])
  companyId       String
  company         Company        @relation(fields: [companyId], references: [id])
  
  dueDate         DateTime?
  startDate       DateTime?
  endDate         DateTime?
  estimatedHours  Float?
  actualHours     Float?
  percentComplete Int            @default(0)
  
  dependencies    String[]       @default([])
  tags            String[]       @default([])
  attachments     Json           @default("[]")
  customFields    Json           @default("{}")
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  completedAt     DateTime?
  deletedAt       DateTime?
  
  @@index([projectId])
  @@index([companyId])
  @@index([status])
  @@index([assigneeId])
  @@index([dueDate])
  @@index([parentTaskId])
}

model WorkPackage {
  id              String         @id @default(cuid())
  code            String         @unique
  name            String
  description     String?        @db.Text
  
  level           Int            @default(1)
  parentWpId      String?
  parentWp        WorkPackage?   @relation("WbsHierarchy", fields: [parentWpId], references: [id])
  childWps        WorkPackage[]  @relation("WbsHierarchy")
  
  projectId       String
  project         Project        @relation(fields: [projectId], references: [id])
  
  startDate       DateTime?
  endDate         DateTime?
  budget          Float          @default(0)
  actualCost      Float          @default(0)
  progress        Int            @default(0)
  
  tasks           Task[]
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  @@index([projectId])
  @@index([code])
  @@index([parentWpId])
}

// ============================================
// MILESTONES
// ============================================

model Milestone {
  id              String          @id @default(cuid())
  name            String
  description     String?         @db.Text
  targetDate      DateTime
  actualDate      DateTime?
  status          MilestoneStatus @default(NOT_STARTED)
  percentComplete Int             @default(0)
  sortOrder       Int             @default(0)
  isCritical      Boolean         @default(false)
  dependencies    String[]        @default([])
  notes           String?         @db.Text
  
  projectId       String
  project         Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdById     String
  createdBy       User            @relation(fields: [createdById], references: [id])
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  @@index([projectId])
  @@index([status])
  @@index([targetDate])
}

// ============================================
// FINANCIAL MANAGEMENT
// ============================================

model CostItem {
  id              String         @id @default(cuid())
  description     String
  category        CostCategory   @default(OTHER)
  status          CostStatus     @default(ESTIMATED)
  estimatedAmount Float          @default(0)
  actualAmount    Float          @default(0)
  committedAmount Float          @default(0)
  invoiceNumber   String?
  invoiceDate     DateTime?
  paidDate        DateTime?
  vendor          String?
  notes           String?        @db.Text
  
  projectId       String
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  companyId       String
  company         Company        @relation(fields: [companyId], references: [id])
  costCodeId      String?
  costCode        CostCode?      @relation(fields: [costCodeId], references: [id])
  createdById     String
  createdBy       User           @relation(fields: [createdById], references: [id])
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  @@index([projectId])
  @@index([category])
  @@index([status])
}

model CostCode {
  id              String         @id @default(cuid())
  code            String         @unique
  title           String
  description     String?        @db.Text
  parentCodeId    String?
  parentCode      CostCode?      @relation("CostCodeHierarchy", fields: [parentCodeId], references: [id])
  childCodes      CostCode[]     @relation("CostCodeHierarchy")
  level           Int            @default(1)
  
  costItems       CostItem[]
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  @@index([code])
  @@index([parentCodeId])
}

model BudgetLine {
  id              String         @id @default(cuid())
  code            String
  description     String
  originalAmount  Float          @default(0)
  revisedAmount   Float          @default(0)
  committedAmount Float          @default(0)
  actualAmount    Float          @default(0)
  forecastAmount  Float          @default(0)
  variance        Float          @default(0)
  variancePercent Float          @default(0)
  
  costCodeId      String?
  costCode        CostCode?      @relation(fields: [costCodeId], references: [id])
  projectId       String
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  companyId       String
  company         Company        @relation(fields: [companyId], references: [id])
  createdById     String
  createdBy       User           @relation(fields: [createdById], references: [id])
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  @@index([projectId])
  @@index([costCodeId])
}

model ChangeOrder {
  id              String             @id @default(cuid())
  number          Int
  title           String
  description     String?            @db.Text
  status          ChangeOrderStatus  @default(DRAFT)
  
  costChange      Float              @default(0)
  scheduleChange  Int                @default(0)
  
  submittedDate   DateTime?
  approvedDate    DateTime?
  approvedById    String?
  approvedBy      User?              @relation("ChangeOrderApprover", fields: [approvedById], references: [id])
  
  version         Int                @default(1)
  
  projectId       String
  project         Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  companyId       String
  company         Company            @relation(fields: [companyId], references: [id])
  createdById     String
  createdBy       User               @relation("ChangeOrderCreator", fields: [createdById], references: [id])
  
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  
  @@unique([projectId, number])
  @@index([projectId])
  @@index([status])
}

// ============================================
// RFI & SUBMITTAL
// ============================================

model RFI {
  id              String         @id @default(cuid())
  number          Int
  rfiNumber       String         @unique
  subject         String
  question        String         @db.Text
  response        String?        @db.Text
  status          RFIStatus      @default(OPEN)
  priority        RFIPriority    @default(MEDIUM)
  
  ballInCourt     String?
  assignedToId    String?
  assignedTo      User?          @relation("RFIAssignee", fields: [assignedToId], references: [id])
  
  costImpact      Boolean        @default(false)
  scheduleImpact  Boolean        @default(false)
  
  dueDate         DateTime?
  responseDate    DateTime?
  closedDate      DateTime?
  
  projectId       String
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  companyId       String
  company         Company        @relation(fields: [companyId], references: [id])
  requestedById   String
  requestedBy     User           @relation("RFIRequester", fields: [requestedById], references: [id])
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  attachments     RFIAttachment[]
  
  @@unique([projectId, number])
  @@index([projectId])
  @@index([status])
  @@index([priority])
}

model RFIAttachment {
  id               String   @id @default(cuid())
  name             String
  cloudStoragePath String
  fileSize         BigInt?
  mimeType         String?
  
  rfiId            String
  rfi              RFI      @relation(fields: [rfiId], references: [id], onDelete: Cascade)
  uploadedById     String?
  uploadedBy       User?    @relation(fields: [uploadedById], references: [id])
  
  createdAt        DateTime @default(now())
  
  @@index([rfiId])
}

model Submittal {
  id              String           @id @default(cuid())
  number          Int
  submittalNumber String           @unique
  title           String
  description     String?          @db.Text
  status          SubmittalStatus  @default(DRAFT)
  revision        Int              @default(0)
  
  type            String           @default("material")
  category        String?
  
  assignedToId    String?
  assignedTo      User?            @relation("SubmittalAssignee", fields: [assignedToId], references: [id])
  
  submittedDate   DateTime?
  reviewedDate    DateTime?
  requiredDate    DateTime?
  
  reviewComments  String?          @db.Text
  action          String?
  
  projectId       String
  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  companyId       String
  company         Company          @relation(fields: [companyId], references: [id])
  submittedById   String
  submittedBy     User             @relation("SubmittalSubmitter", fields: [submittedById], references: [id])
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  
  attachments     SubmittalAttachment[]
  
  @@unique([projectId, number])
  @@index([projectId])
  @@index([status])
}

model SubmittalAttachment {
  id               String   @id @default(cuid())
  name             String
  cloudStoragePath String
  fileSize         BigInt?
  mimeType         String?
  
  submittalId      String
  submittal        Submittal @relation(fields: [submittalId], references: [id], onDelete: Cascade)
  uploadedById     String?
  uploadedBy       User?    @relation(fields: [uploadedById], references: [id])
  
  createdAt        DateTime @default(now())
  
  @@index([submittalId])
}

// ============================================
// SAFETY MANAGEMENT
// ============================================

model SafetyIncident {
  id              String           @id @default(cuid())
  incidentNumber  String           @unique
  title           String
  description     String           @db.Text
  
  severity        IncidentSeverity @default(LOW)
  status          IncidentStatus   @default(REPORTED)
  
  occurrenceDate  DateTime
  location        String
  weatherConditions String?
  workActivity    String?          @db.Text
  
  injuredCount    Int              @default(0)
  fatalities      Int              @default(0)
  injuredPartyIds String[]         @default([])
  witnesses       String[]         @default([])
  
  reportedById    String
  reportedBy      User             @relation("IncidentReporter", fields: [reportedById], references: [id])
  investigatorId  String?
  investigator    User?            @relation("IncidentInvestigator", fields: [investigatorId], references: [id])
  
  investigationStartDate DateTime?
  investigationEndDate   DateTime?
  rootCause         String?        @db.Text
  correctiveActions String?        @db.Text
  preventiveActions String?        @db.Text
  
  costImpact      Float?
  lostWorkDays    Int              @default(0)
  
  oshaRecordable    Boolean        @default(false)
  reportedToAuthority Boolean      @default(false)
  authorityReportDate DateTime?
  
  projectId       String
  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  companyId       String
  company         Company          @relation(fields: [companyId], references: [id])
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  
  photos          IncidentPhoto[]
  documents       IncidentDocument[]
  
  @@index([projectId])
  @@index([status])
  @@index([severity])
  @@index([occurrenceDate])
}

model IncidentPhoto {
  id               String   @id @default(cuid())
  incidentId       String
  incident         SafetyIncident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  cloudStoragePath String
  caption          String?
  uploadedById     String?
  uploadedBy       User?    @relation(fields: [uploadedById], references: [id])
  createdAt        DateTime @default(now())
  
  @@index([incidentId])
}

model IncidentDocument {
  id               String   @id @default(cuid())
  incidentId       String
  incident         SafetyIncident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  type             String
  cloudStoragePath String
  uploadedById     String?
  uploadedBy       User?    @relation(fields: [uploadedById], references: [id])
  createdAt        DateTime @default(now())
  
  @@index([incidentId])
}

model RiskAssessment {
  id              String         @id @default(cuid())
  ramNumber       String         @unique
  title           String
  description     String         @db.Text
  
  hazard          String
  potentialHarm   String         @db.Text
  existingControls String?       @db.Text
  
  likelihoodBefore Int          @default(1)
  consequenceBefore Int         @default(1)
  riskLevelBefore  String
  
  likelihoodAfter  Int          @default(1)
  consequenceAfter Int          @default(1)
  riskLevelAfter   String
  
  controlMeasures  String[]     @default([])
  additionalControls String?    @db.Text
  
  status          String         @default("IDENTIFIED")
  
  assessedById    String
  assessedBy      User           @relation("RiskAssessor", fields: [assessedById], references: [id])
  reviewedById    String?
  reviewedBy      User?          @relation("RiskReviewer", fields: [reviewedById], references: [id])
  approvedById    String?
  approvedBy      User?          @relation("RiskApprover", fields: [approvedById], references: [id])
  
  projectId       String
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  companyId       String
  company         Company        @relation(fields: [companyId], references: [id])
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  reviewedDate    DateTime?
  approvedDate    DateTime?
  
  tasks           RiskTask[]
  
  @@index([projectId])
  @@index([status])
}

model RiskTask {
  id              String         @id @default(cuid())
  riskAssessmentId String
  riskAssessment  RiskAssessment @relation(fields: [riskAssessmentId], references: [id], onDelete: Cascade)
  
  action          String
  responsible     String?
  dueDate         DateTime?
  status          String         @default("pending")
  completedDate   DateTime?
  notes           String?        @db.Text
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  @@index([riskAssessmentId])
}

model PermitToWork {
  id              String         @id @default(cuid())
  permitNumber    String         @unique
  title           String
  description     String         @db.Text
  
  type            String         @default("GENERAL")
  status          String         @default("DRAFT")
  
  location        String
  area            String?
  
  requestedStart  DateTime
  requestedEnd    DateTime
  actualStart     DateTime?
  actualEnd       DateTime?
  extendedUntil   DateTime?
  
  workDescription String         @db.Text
  equipmentUsed   String?        @db.Text
  materialsUsed   String?        @db.Text
  
  hazards         String[]       @default([])
  precautions     String[]       @default([])
  
  requestedById   String
  requestedBy     User           @relation("PermitRequester", fields: [requestedById], references: [id])
  approvedById    String?
  approvedBy      User?          @relation("PermitApprover", fields: [approvedById], references: [id])
  supervisorId    String?
  supervisor      User?          @relation("PermitSupervisor", fields: [supervisorId], references: [id])
  
  workerNames     String[]       @default([])
  workerCount     Int            @default(0)
  
  safetyChecklist Json           @default("{}")
  gasTestRequired Boolean        @default(false)
  gasTestResult   String?
  
  authorizedStart String?
  authorizedEnd   String?
  
  projectId       String
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  companyId       String
  company         Company        @relation(fields: [companyId], references: [id])
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  submittedDate   DateTime?
  approvedDate    DateTime?
  closedDate      DateTime?
  
  extensions      PermitExtension[]
  checks          PermitCheck[]
  
  @@index([projectId])
  @@index([status])
  @@index([type])
}

model PermitExtension {
  id              String         @id @default(cuid())
  permitId        String
  permit          PermitToWork   @relation(fields: [permitId], references: [id], onDelete: Cascade)
  
  extensionNumber Int            @default(1)
  reason          String         @db.Text
  extendedUntil   DateTime
  approvedById    String
  approvedBy      User           @relation(fields: [approvedById], references: [id])
  
  createdAt       DateTime       @default(now())
  
  @@index([permitId])
}

model PermitCheck {
  id              String         @id @default(cuid())
  permitId        String
  permit          PermitToWork   @relation(fields: [permitId], references: [id], onDelete: Cascade)
  
  checkType       String
  checkedById     String
  checkedBy       User           @relation(fields: [checkedById], references: [id])
  checkedAt       DateTime       @default(now())
  notes           String?        @db.Text
  
  createdAt       DateTime       @default(now())
  
  @@index([permitId])
}

model ToolboxTalk {
  id              String         @id @default(cuid())
  talkNumber      String         @unique
  title           String
  topic           String
  description     String         @db.Text
  
  deliveredDate   DateTime
  duration        Int            @default(15)
  location        String
  
  keyPoints       String[]       @default([])
  hazardsDiscussed String[]      @default([])
  controlsDiscussed String[]     @default([])
  
  presenterId     String
  presenter       User           @relation("ToolboxTalkPresenter", fields: [presenterId], references: [id])
  attendees       String[]       @default([])
  attendeeCount   Int            @default(0)
  
  photos          String[]       @default([])
  documents       String[]       @default([])
  
  projectId       String
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  companyId       String
  company         Company        @relation(fields: [companyId], references: [id])
  createdById     String
  createdBy       User           @relation("ToolboxTalkCreator", fields: [createdById], references: [id])
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  @@index([projectId])
  @@index([deliveredDate])
}

// ============================================
// QUALITY MANAGEMENT
// ============================================

model QualityCheck {
  id              String         @id @default(cuid())
  checkNumber     String         @unique
  title           String
  description     String?        @db.Text
  
  type            String         @default("inspection")
  category        String?
  
  status          InspectionStatus @default(SCHEDULED)
  priority        String         @default("normal")
  
  scheduledDate   DateTime
  completedDate   DateTime?
  location        String?
  
  checklist       Json           @default("{}")
  results         Json           @default("{}")
  findings        String?        @db.Text
  recommendations String?        @db.Text
  
  inspectorId     String
  inspector       User           @relation("QualityInspector", fields: [inspectorId], references: [id])
  witnesses       String[]       @default([])
  
  projectId       String
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  companyId       String
  company         Company        @relation(fields: [companyId], references: [id])
  
  defects         Defect[]
  photos          QualityPhoto[]
  documents       QualityDocument[]
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  @@index([projectId])
  @@index([status])
  @@index([scheduledDate])
}

model Defect {
  id              String          @id @default(cuid())
  defectNumber    String          @unique
  title           String
  description     String          @db.Text
  
  category        String          @default("workmanship")
  classification  String?
  
  priority        DefectPriority  @default(MEDIUM)
  status          DefectStatus    @default(IDENTIFIED)
  
  location        String          @db.Text
  element         String?
  system          String?
  
  identifiedById  String
  identifiedBy    User            @relation("DefectIdentifier", fields: [identifiedById], references: [id])
  assignedToId    String?
  assignedTo      User?           @relation("DefectAssignee", fields: [assignedToId], references: [id])
  
  identifiedDate  DateTime
  dueDate         DateTime?
  resolvedDate    DateTime?
  verifiedDate    DateTime?
  
  resolution      String?         @db.Text
  verification    String?         @db.Text
  
  costImpact      Float?
  scheduleImpact  Int?
  
  projectId       String
  project         Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  companyId       String
  company         Company         @relation(fields: [companyId], references: [id])
  qualityCheckId  String?
  qualityCheck    QualityCheck?   @relation(fields: [qualityCheckId], references: [id])
  
  photos          DefectPhoto[]
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  @@index([projectId])
  @@index([status])
  @@index([priority])
}

model DefectPhoto {
  id               String   @id @default(cuid())
  defectId         String
  defect           Defect   @relation(fields: [defectId], references: [id], onDelete: Cascade)
  cloudStoragePath String
  caption          String?
  uploadedById     String?
  uploadedBy       User?    @relation(fields: [uploadedById], references: [id])
  isBefore         Boolean  @default(false)
  isAfter          Boolean  @default(false)
  createdAt        DateTime @default(now())
  
  @@index([defectId])
}

model QualityPhoto {
  id               String   @id @default(cuid())
  qualityCheckId   String
  qualityCheck     QualityCheck @relation(fields: [qualityCheckId], references: [id], onDelete: Cascade)
  cloudStoragePath String
  caption          String?
  uploadedById     String?
  uploadedBy       User?    @relation(fields: [uploadedById], references: [id])
  createdAt        DateTime @default(now())
  
  @@index([qualityCheckId])
}

model QualityDocument {
  id               String   @id @default(cuid())
  qualityCheckId   String
  qualityCheck     QualityCheck @relation(fields: [qualityCheckId], references: [id], onDelete: Cascade)
  type             String
  cloudStoragePath String
  uploadedById     String?
  uploadedBy       User?    @relation(fields: [uploadedById], references: [id])
  createdAt        DateTime @default(now())
  
  @@index([qualityCheckId])
}

// ============================================
// EQUIPMENT & MATERIALS
// ============================================

model Equipment {
  id              String         @id @default(cuid())
  name            String
  description     String?        @db.Text
  serialNumber    String?
  model           String?
  manufacturer    String?
  
  category        String         @default("heavy")
  type            EquipmentType  @default(OWNED)
  status          EquipmentStatus @default(AVAILABLE)
  
  condition       String         @default("good")
  conditionNote   String?        @db.Text
  
  purchaseDate    DateTime?
  purchasePrice   Float?
  currentValue    Float?
  depreciation    Float?
  
  lastServiceDate DateTime?
  nextServiceDate DateTime?
  serviceInterval Int            @default(90)
  
  location        String?
  assignedToId    String?
  assignedTo      User?          @relation("EquipmentAssignee", fields: [assignedToId], references: [id])
  
  projectId       String
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  companyId       String
  company         Company        @relation(fields: [companyId], references: [id])
  
  hourlyRate      Float?
  operatingCost   Float?
  
  meterReading    Float?
  meterUnit       String         @default("hours")
  
  insuranceExpiry DateTime?
  certificationExpiry DateTime?
  
  notes           String?        @db.Text
  metadata        Json           @default("{}")
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  logs            EquipmentLog[]
  maintenances    EquipmentMaintenance[]
  
  @@index([projectId])
  @@index([status])
  @@index([category])
}

model EquipmentLog {
  id              String         @id @default(cuid())
  equipmentId     String
  equipment       Equipment      @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  
  logDate         DateTime       @default(now())
  operatorId      String
  operator        User           @relation(fields: [operatorId], references: [id])
  
  startHour       Float
  endHour         Float
  hoursUsed       Float
  
  workDescription String?        @db.Text
  location        String?
  
  fuelUsed        Float?
  fuelUnit        String         @default("liters")
  
  notes           String?        @db.Text
  
  createdAt       DateTime       @default(now())
  
  @@index([equipmentId])
  @@index([logDate])
}

model EquipmentMaintenance {
  id              String         @id @default(cuid())
  equipmentId     String
  equipment       Equipment      @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  
  type            String         @default("preventive")
  title           String
  description     String?        @db.Text
  
  scheduledDate   DateTime
  completedDate   DateTime?
  
  performedById   String
  performedBy     User           @relation(fields: [performedById], references: [id])
  
  cost            Float          @default(0)
  partsUsed       String[]       @default([])
  laborHours      Float?
  
  workOrder       String?        @db.Text
  vendor          String?
  
  nextDueDate     DateTime?
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  @@index([equipmentId])
  @@index([scheduledDate])
}

model Material {
  id              String         @id @default(cuid())
  name            String
  description     String?        @db.Text
  
  category        String         @default("general")
  type            MaterialType   @default(CONSUMABLE)
  status          MaterialStatus @default(IN_STOCK)
  
  sku             String?
  barcode         String?
  manufacturer    String?
  supplier        String?
  
  quantity        Float          @default(0)
  unit            String         @default("piece")
  unitPrice       Float          @default(0)
  totalValue      Float          @default(0)
  
  location        String?
  warehouse       String?
  
  reorderLevel    Float?
  reorderQuantity Float?
  
  expiryDate      DateTime?
  batchNumber     String?
  
  projectId       String
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  companyId       String
  company         Company        @relation(fields: [companyId], references: [id])
  createdById     String
  createdBy       User           @relation("MaterialCreator", fields: [createdById], references: [id])
  
  metadata        Json           @default("{}")
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  transactions    MaterialTransaction[]
  
  @@index([projectId])
  @@index([category])
  @@index([status])
}

model MaterialTransaction {
  id              String         @id @default(cuid())
  materialId      String
  material        Material       @relation(fields: [materialId], references: [id], onDelete: Cascade)
  
  type            String         @default("receipt")
  quantity        Float
  unit            String
  
  reference       String?
  referenceType   String?
  
  fromLocation    String?
  toLocation      String?
  
  performedById   String
  performedBy     User           @relation(fields: [performedById], references: [id])
  
  notes           String?        @db.Text
  
  createdAt       DateTime       @default(now())
  
  @@index([materialId])
  @@index([type])
}

// ============================================
// TIME TRACKING & WEATHER
// ============================================

model TimeEntry {
  id              String         @id @default(cuid())
  date            DateTime
  startTime       DateTime
  endTime         DateTime
  duration        Float
  
  type            String         @default("regular")
  category        String?
  
  status          TimeEntryStatus @default(DRAFT)
  
  billable        Boolean        @default(false)
  billRate        Float?
  
  hourlyRate      Float?
  totalAmount     Float?
  
  workDescription String?        @db.Text
  location        String?
  
  projectId       String
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  companyId       String
  company         Company        @relation(fields: [companyId], references: [id])
  userId          String
  user            User           @relation("TimeEntryUser", fields: [userId], references: [id])
  
  approvedById    String?
  approvedBy      User?          @relation("TimeEntryApprover", fields: [approvedById], references: [id])
  approvedAt      DateTime?
  
  payrollPeriodId String?
  processed       Boolean        @default(false)
  processedAt     DateTime?
  
  metadata        Json           @default("{}")
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  @@index([userId])
  @@index([projectId])
  @@index([date])
  @@index([status])
}

model PayrollPeriod {
  id              String         @id @default(cuid())
  name            String
  startDate       DateTime
  endDate         DateTime
  
  status          String         @default("open")
  
  companyId       String
  company         Company        @relation(fields: [companyId], references: [id])
  
  totalHours      Float          @default(0)
  totalAmount     Float          @default(0)
  
  processedById   String?
  processedBy     User?          @relation(fields: [processedById], references: [id])
  processedAt     DateTime?
  
  notes           String?        @db.Text
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  timeEntries     TimeEntry[]
  
  @@index([companyId])
  @@index([startDate])
}

model WeatherLog {
  id              String         @id @default(cuid())
  date            DateTime
  
  temperature     Float?
  temperatureUnit String         @default("C")
  
  humidity        Float?
  windSpeed       Float?
  windDirection   String?
  
  conditions      WeatherCondition?
  precipitation   Float?
  
  visibility      Float?
  pressure        Float?
  
  sunrise         DateTime?
  sunset          DateTime?
  
  workable        Boolean        @default(true)
  workableNote    String?        @db.Text
  
  recordedById    String
  recordedBy      User           @relation("WeatherLogRecorder", fields: [recordedById], references: [id])
  
  projectId       String
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  companyId       String
  company         Company        @relation(fields: [companyId], references: [id])
  
  createdAt       DateTime       @default(now())
  
  @@unique([projectId, date])
  @@index([projectId])
  @@index([date])
}

model DailyLog {
  id              String         @id @default(cuid())
  logNumber       String         @unique
  date            DateTime
  
  weather         String?        @db.Text
  temperature     Float?
  
  workPerformed   String         @db.Text
  workLocation    String?
  
  headcount       Int            @default(0)
  visitorCount    Int            @default(0)
  
  equipmentUsed   String[]       @default([])
  materialsDelivered String[]    @default([])
  
  activities      String[]       @default([])
  accomplishments String         @db.Text
  
  issues          String?        @db.Text
  delays          String?        @db.Text
  accidents       String?        @db.Text
  
  visitors        String[]       @default([])
  deliveries      String[]       @default([])
  
  photos          String[]       @default([])
  
  projectId       String
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  companyId       String
  company         Company        @relation(fields: [companyId], references: [id])
  createdById     String
  createdBy       User           @relation("DailyLogCreator", fields: [createdById], references: [id])
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  @@index([projectId])
  @@index([date])
}

model SiteDiary {
  id              String         @id @default(cuid())
  entryNumber     String         @unique
  date            DateTime
  
  title           String
  content         String         @db.Text
  
  mood            String?
  productivity    String?
  
  highlights      String[]       @default([])
  challenges      String[]       @default([])
  
  weather         String?
  temperature     Float?
  
  teamPresent     String[]       @default([])
  visitors        String[]       @default([])
  
  photos          String[]       @default([])
  
  projectId       String
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  companyId       String
  company         Company        @relation(fields: [companyId], references: [id])
  authorId        String
  author          User           @relation("SiteDiaryAuthor", fields: [authorId], references: [id])
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  @@index([projectId])
  @@index([date])
}

// ============================================
// DOCUMENTS & DRAWINGS
// ============================================

model Document {
  id              String         @id @default(cuid())
  number          String         @unique
  title           String
  description     String?        @db.Text
  
  type            DocumentType   @default(GENERAL)
  category        String?
  discipline      String?
  
  revision        String         @default("0")
  revisionStatus  String         @default("draft")
  
  fileSize        BigInt
  mimeType        String
  cloudStoragePath String
  
  version         Int            @default(1)
  
  uploadedById    String
  uploadedBy      User           @relation("DocumentUploader", fields: [uploadedById], references: [id])
  
  projectId       String
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  companyId       String
  company         Company        @relation(fields: [companyId], references: [id])
  
  tags            String[]       @default([])
  metadata        Json           @default("{}")
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  versions        DocumentVersion[]
  
  @@index([projectId])
  @@index([type])
  @@index([number])
}

model DocumentVersion {
  id              String         @id @default(cuid())
  documentId      String
  document        Document       @relation(fields: [documentId], references: [id], onDelete: Cascade)
  
  version         Int
  revision        String
  
  cloudStoragePath String
  fileSize        BigInt
  mimeType        String
  
  changeNotes     String?        @db.Text
  
  uploadedById    String
  uploadedBy      User           @relation(fields: [uploadedById], references: [id])
  
  createdAt       DateTime       @default(now())
  
  @@index([documentId])
  @@index([version])
}

model Drawing {
  id              String         @id @default(cuid())
  number          String         @unique
  title           String
  description     String?        @db.Text
  
  discipline      DrawingDiscipline @default(ARCHITECTURAL)
  type            String         @default("plan")
  
  revision        String         @default("0")
  revisionStatus  String         @default("issued")
  
  fileSize        BigInt
  mimeType        String
  cloudStoragePath String
  
  scale           String?
  sheetSize       String?
  
  issuedDate      DateTime?
  receivedDate    DateTime?
  
  uploadedById    String
  uploadedBy      User           @relation("DrawingUploader", fields: [uploadedById], references: [id])
  
  projectId       String
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  companyId       String
  company         Company        @relation(fields: [companyId], references: [id])
  
  tags            String[]       @default([])
  metadata        Json           @default("{}")
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  @@index([projectId])
  @@index([discipline])
  @@index([number])
}

model Permit {
  id              String         @id @default(cuid())
  permitNumber    String         @unique
  title           String
  description     String?        @db.Text
  
  type            PermitType     @default(BUILDING)
  authority       String
  
  status          String         @default("pending")
  
  submittedDate   DateTime?
  approvedDate    DateTime?
  expiryDate      DateTime?
  
  conditions      String?        @db.Text
  fees            Float?
  
  projectId       String
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  companyId       String
  company         Company        @relation(fields: [companyId], references: [id])
  createdById     String
  createdBy       User           @relation("PermitCreator", fields: [createdById], references: [id])
  
  documents       String[]       @default([])
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  @@index([projectId])
  @@index([type])
  @@index([status])
}

// ============================================
// PROGRESS CLAIMS
// ============================================

model ProgressClaim {
  id              String         @id @default(cuid())
  claimNumber     String         @unique
  title           String
  
  claimDate       DateTime
  periodStart     DateTime
  periodEnd       DateTime
  
  status          ClaimStatus    @default(DRAFT)
  
  claimedAmount   Float          @default(0)
  approvedAmount  Float?
  paidAmount      Float?
  retainedAmount  Float?
  retentionPercent Float         @default(10)
  
  previousClaimed Float          @default(0)
  previousPaid    Float          @default(0)
  
  thisPeriod      Float          @default(0)
  toDate          Float          @default(0)
  
  balanceToEarn   Float          @default(0)
  
  submittedById   String
  submittedBy     User           @relation("ClaimSubmitter", fields: [submittedById], references: [id])
  approvedById    String?
  approvedBy      User?          @relation("ClaimApprover", fields: [approvedById], references: [id])
  
  submittedDate   DateTime?
  approvedDate    DateTime?
  paidDate        DateTime?
  
  notes           String?        @db.Text
  
  projectId       String
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  companyId       String
  company         Company        @relation(fields: [companyId], references: [id])
  
  lineItems       ProgressClaimLine[]
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  @@index([projectId])
  @@index([status])
  @@index([claimDate])
}

model ProgressClaimLine {
  id              String         @id @default(cuid())
  claimId         String
  claim           ProgressClaim  @relation(fields: [claimId], references: [id], onDelete: Cascade)
  
  lineNumber      Int
  description     String
  
  originalAmount  Float
  revisedAmount   Float
  
  previousAmount  Float
  thisPeriod      Float
  toDate          Float
  
  retention       Float
  netAmount       Float
  
  @@index([claimId])
}

// ============================================
// COMMUNICATION & NOTIFICATIONS
// ============================================

model Notification {
  id              String         @id @default(cuid())
  title           String
  message         String         @db.Text
  
  type            String         @default("info")
  priority        String         @default("normal")
  
  status          NotificationStatus @default(PENDING)
  
  recipientId     String
  recipient       User           @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  
  actorId         String?
  actor           User?          @relation("NotificationActor", fields: [actorId], references: [id])
  
  organizationId  String
  organization    Organization   @relation(fields: [organizationId], references: [id])
  
  entityType      String?
  entityId        String?
  
  channel         String         @default("in_app")
  
  sentAt          DateTime?
  deliveredAt     DateTime?
  readAt          DateTime?
  
  metadata        Json           @default("{}")
  
  createdAt       DateTime       @default(now())
  
  @@index([recipientId])
  @@index([status])
  @@index([createdAt])
  @@index([organizationId])
}

model Communication {
  id              String         @id @default(cuid())
  subject         String
  message         String         @db.Text
  
  type            String         @default("message")
  channel         String         @default("email")
  
  status          String         @default("draft")
  
  fromId          String
  from            User           @relation("CommunicationSender", fields: [fromId], references: [id])
  
  toIds           String[]       @default([])
  ccIds           String[]       @default([])
  bccIds          String[]       @default([])
  
  attachments     String[]       @default([])
  
  sentAt          DateTime?
  deliveredAt     DateTime?
  readAt          DateTime?
  
  inReplyToId     String?
  inReplyTo       Communication? @relation(fields: [inReplyToId], references: [id])
  
  projectId       String?
  project         Project?       @relation(fields: [projectId], references: [id])
  
  metadata        Json           @default("{}")
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  @@index([fromId])
  @@index([status])
}

// ============================================
// WORKFLOW & APPROVALS
// ============================================

model Workflow {
  id              String         @id @default(cuid())
  name            String
  description     String?        @db.Text
  
  type            String         @default("custom")
  category        String?
  
  status          WorkflowStatus @default(DRAFT)
  version         Int            @default(1)
  
  trigger         Json           @default("{}")
  nodes           Json           @default("[]")
  edges           Json           @default("[]")
  
  isActive        Boolean        @default(false)
  isTemplate      Boolean        @default(false)
  
  runs            Int            @default(0)
  lastRunAt       DateTime?
  
  createdById     String
  createdBy       User           @relation("WorkflowCreator", fields: [createdById], references: [id])
  
  projectId       String?
  project         Project?       @relation(fields: [projectId], references: [id])
  organizationId  String
  organization    Organization   @relation(fields: [organizationId], references: [id])
  companyId       String
  company         Company        @relation(fields: [companyId], references: [id])
  
  executions      WorkflowExecution[]
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  @@index([companyId])
  @@index([status])
  @@index([type])
  @@index([organizationId])
}

model WorkflowExecution {
  id              String         @id @default(cuid())
  workflowId      String
  workflow        Workflow       @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  
  status          JobStatus      @default(PENDING)
  
  triggeredBy     String
  triggerData     Json           @default("{}")
  
  currentStep     Int            @default(0)
  totalSteps      Int            @default(0)
  
  result          Json?
  error           String?        @db.Text
  
  startedAt       DateTime?
  completedAt     DateTime?
  
  createdAt       DateTime       @default(now())
  
  @@index([workflowId])
  @@index([status])
}

model Approval {
  id              String         @id @default(cuid())
  approvalNumber  String         @unique
  
  entityType      String
  entityId        String
  
  type            String         @default("general")
  status          ApprovalStatus @default(PENDING)
  
  requestedById   String
  requestedBy     User           @relation("ApprovalRequester", fields: [requestedById], references: [id])
  
  approverId      String
  approver        User           @relation("ApprovalApprover", fields: [approverId], references: [id])
  
  delegateId      String?
  delegate        User?          @relation("ApprovalDelegate", fields: [delegateId], references: [id])
  
  requestedAt     DateTime       @default(now())
  dueDate         DateTime?
  decidedAt       DateTime?
  
  decision        String?        @db.Text
  comments        String?        @db.Text
  
  escalated       Boolean        @default(false)
  escalatedAt     DateTime?
  escalatedToId   String?
  escalatedTo     User?          @relation("ApprovalEscalated", fields: [escalatedToId], references: [id])
  
  projectId       String?
  project         Project?       @relation(fields: [projectId], references: [id])
  companyId       String
  company         Company        @relation(fields: [companyId], references: [id])
  
  metadata        Json           @default("{}")
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  @@index([entityType, entityId])
  @@index([status])
  @@index([approverId])
}

// ============================================
// INTEGRATIONS & API
// ============================================

model Integration {
  id              String         @id @default(cuid())
  name            String
  description     String?        @db.Text
  
  provider        String         @default("custom")
  type            String         @default("oauth")
  
  status          String         @default("inactive")
  
  credentials     Json           @default("{}")
  config          Json           @default("{}")
  scopes          String[]       @default([])
  
  lastSyncAt      DateTime?
  syncStatus      String?        @db.Text
  
  webhookUrl      String?
  webhookSecret   String?
  
  organizationId  String
  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  metadata        Json           @default("{}")
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  @@index([organizationId])
  @@index([provider])
}

model ApiKey {
  id              String         @id @default(cuid())
  name            String
  description     String?        @db.Text
  
  key             String         @unique
  prefix          String
  
  organizationId  String
  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  userId          String?
  user            User?          @relation(fields: [userId], references: [id])
  
  scopes          String[]       @default([])
  permissions     Json           @default("{}")
  
  rateLimit       Int?
  rateLimitPeriod String         @default("hour")
  
  expiresAt       DateTime?
  lastUsedAt      DateTime?
  
  isActive        Boolean        @default(true)
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  @@index([organizationId])
  @@index([key])
}

model Webhook {
  id              String         @id @default(cuid())
  name            String
  description     String?        @db.Text
  
  url             String
  secret          String         @unique
  
  events          String[]       @default([])
  
  organizationId  String
  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  userId          String?
  user            User?          @relation(fields: [userId], references: [id])
  
  active          Boolean        @default(true)
  
  lastTriggeredAt DateTime?
  failureCount    Int            @default(0)
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  @@index([organizationId])
  @@index([active])
}

// ============================================
// AUDIT & ANALYTICS
// ============================================

model AuditLog {
  id              String         @id @default(cuid())
  action          AuditAction
  entityType      String
  entityId        String
  
  actorId         String?
  actor           User?          @relation(fields: [actorId], references: [id])
  
  organizationId  String
  organization    Organization   @relation(fields: [organizationId], references: [id])
  
  changes         Json           @default("{}")
  metadata        Json           @default("{}")
  
  ipAddress       String?
  userAgent       String?
  
  createdAt       DateTime       @default(now())
  
  @@index([actorId])
  @@index([entityType, entityId])
  @@index([organizationId])
  @@index([createdAt])
}

model Analytics {
  id              String         @id @default(cuid())
  eventType       String
  eventName       String
  
  value           Float?
  unit            String?
  
  dimensions      Json           @default("{}")
  metrics         Json           @default("{}")
  
  organizationId  String
  organization    Organization   @relation(fields: [organizationId], references: [id])
  
  projectId       String?
  project         Project?       @relation(fields: [projectId], references: [id])
  
  userId          String?
  user            User?          @relation(fields: [userId], references: [id])
  
  timestamp       DateTime       @default(now())
  
  @@index([organizationId])
  @@index([eventType])
  @@index([timestamp])
}

model Report {
  id              String         @id @default(cuid())
  name            String
  description     String?        @db.Text
  
  type            String         @default("standard")
  format          String         @default("pdf")
  
  config          Json           @default("{}")
  filters         Json           @default("{}")
  columns         Json           @default("{}")
  
  status          String         @default("pending")
  
  generatedBy     String
  generatedById   String
  generatedByUser User           @relation(fields: [generatedById], references: [id])
  
  outputUrl       String?
  fileSize        BigInt?
  
  organizationId  String
  organization    Organization   @relation(fields: [organizationId], references: [id])
  
  projectId       String?
  project         Project?       @relation(fields: [projectId], references: [id])
  
  scheduled       Boolean        @default(false)
  schedule        String?
  
  createdAt       DateTime       @default(now())
  completedAt     DateTime?
  
  @@index([organizationId])
  @@index([type])
}

// ============================================
// STORAGE & JOBS
// ============================================

model Storage {
  id              String         @id @default(cuid())
  name            String
  originalName    String
  
  path            String
  provider        StorageProvider @default(LOCAL)
  
  bucket          String?
  region          String?
  
  fileSize        BigInt
  mimeType        String
  
  ownerId         String?
  owner           User?          @relation(fields: [ownerId], references: [id])
  
  organizationId  String
  organization    Organization   @relation(fields: [organizationId], references: [id])
  
  projectId       String?
  project         Project?       @relation(fields: [projectId], references: [id])
  
  isPublic        Boolean        @default(false)
  isEncrypted     Boolean        @default(false)
  
  metadata        Json           @default("{}")
  
  createdAt       DateTime       @default(now())
  
  @@index([organizationId])
  @@index([ownerId])
  @@index([path])
}

model Job {
  id              String         @id @default(cuid())
  type            JobType
  name            String
  
  status          JobStatus      @default(PENDING)
  priority        Int            @default(5)
  
  attempts        Int            @default(0)
  maxAttempts     Int            @default(3)
  
  payload         Json           @default("{}")
  result          Json?
  error           String?        @db.Text
  
  scheduledAt     DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  
  failedAt        DateTime?
  failureReason   String?        @db.Text
  
  nextAttemptAt   DateTime?
  
  workerId        String?
  
  organizationId  String
  organization    Organization   @relation(fields: [organizationId], references: [id])
  
  projectId       String?
  project         Project?       @relation(fields: [projectId], references: [id])
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  @@index([status])
  @@index([type])
  @@index([scheduledAt])
  @@index([organizationId])
}
