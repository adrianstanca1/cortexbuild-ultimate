# Docker Compose Environment Variables
# Copy this file to .env and update with your own secure values
# NEVER commit .env with real credentials to git

# PostgreSQL Database
POSTGRES_USER=cortexbuild
POSTGRES_PASSWORD=CHANGE_ME_USE_SECURE_PASSWORD
POSTGRES_DB=cortexbuild

# JWT Secret (generate with: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_USE_SECURE_SECRET

# Grafana Admin Password
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME_USE_SECURE_PASSWORD

# Redis
REDIS_PASSWORD=

# Ollama
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=qwen3.5:latest

# API
PORT=3001
DATABASE_URL=postgresql://cortexbuild:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?schema=public
