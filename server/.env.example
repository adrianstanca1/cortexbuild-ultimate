# CortexBuild Ultimate - Server Environment Variables
# Copy to .env and fill in values

# Database — use either DATABASE_URL (recommended for Neon/Render/Supabase) OR discrete vars below
# DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require
# Force TLS in dev when not using a known host pattern: DATABASE_SSL=true
# Stricter TLS verify (optional): DATABASE_SSL_REJECT_UNAUTHORIZED=true
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cortexbuild
DB_USER=cortexbuild
DB_PASSWORD=your_secure_password_here

# Redis
REDIS_URL=redis://localhost:6379

# Cursor / agent NDJSON debug sink (optional). If NODE_ENV=production locally, set to 1 so
# POST /api/agent-debug is registered for session logging into the repo.
# ENABLE_AGENT_DEBUG_API=1

# Auth & Security
JWT_SECRET=generate_a_secure_random_string_here_min_32_chars
SESSION_SECRET=same_as_jwt_secret_or_different
# Optional: express-session cookie SameSite (default lax).
# SESSION_COOKIE_SAMESITE=lax
# Optional: share auth cookie between apex and www.
# AUTH_TOKEN_COOKIE_DOMAIN=.cortexbuildpro.com
# Production: if Redis errors during JWT blacklist lookup, deny the request (fail closed).
# Set TOKEN_BLACKLIST_FAIL_OPEN=true only to allow logins when Redis is broken (reduces security).
# TOKEN_BLACKLIST_FAIL_OPEN=
FRONTEND_URL=https://www.cortexbuildpro.com
CORS_ORIGIN=https://cortexbuildpro.com,https://www.cortexbuildpro.com

# OAuth - Google (get from console.cloud.google.com)
# Authorized redirect URI must match GOOGLE_CALLBACK_URL exactly.
# Local Docker: use API port so the OAuth session cookie matches the callback host.
# Prefer **localhost** in the URL so it matches what most people paste into Google Console.
# GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback
# The SPA passes ?return_origin= so you still land back on your Vite port after sign-in.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://www.cortexbuildpro.com/api/auth/google/callback

# OAuth - Microsoft (get from portal.azure.com)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common
MICROSOFT_CALLBACK_URL=https://www.cortexbuildpro.com/api/auth/microsoft/callback

# AI / Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3.5:latest
EMBEDDING_MODEL=nomic-embed-text

# AI Chat tuning
MAX_CONTEXT_MESSAGES=20
SUMMARY_THRESHOLD=10

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@cortexbuildpro.com

# Redis (Docker uses REDIS_HOST, local uses REDIS_URL)
REDIS_HOST=redis

# Deploy webhook secret
DEPLOY_SECRET=

# Server
PORT=3001
NODE_ENV=production
