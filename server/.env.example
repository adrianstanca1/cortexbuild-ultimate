# ═══════════════════════════════════════════════════════════════════════════════
# CortexBuild Ultimate - Backend Server Environment
# ═══════════════════════════════════════════════════════════════════════════════
# 
# SECURITY WARNING: Never commit this file! Already in .gitignore.
# Place this file at: server/.env
#
# Generate secrets with:
#   - 64 char hex: openssl rand -hex 32
#   - DB password: Use strong password (16+ chars)
# ═══════════════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────────────
# DATABASE CONFIGURATION (Required)
# ───────────────────────────────────────────────────────────────────────────────

# Database host (use 'postgres' for Docker, '127.0.0.1' for local)
DB_HOST=127.0.0.1

# Database port
DB_PORT=5432

# Database name
DB_NAME=cortexbuild

# Database user
DB_USER=cortexbuild

# Database password (REQUIRED - server won't start without this)
DB_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD

# ───────────────────────────────────────────────────────────────────────────────
# AUTHENTICATION (Required for production)
# ───────────────────────────────────────────────────────────────────────────────

# JWT secret for token signing (generate: openssl rand -hex 32)
# IMPORTANT: Change this in production!
JWT_SECRET=CHANGE_ME_USE_64_CHARACTER_HEX_STRING

# ───────────────────────────────────────────────────────────────────────────────
# SERVER CONFIGURATION
# ───────────────────────────────────────────────────────────────────────────────

# API server port
PORT=3001

# CORS origin (required for production, comma-separated)
CORS_ORIGIN=https://cortexbuildpro.com,https://www.cortexbuildpro.com

# ───────────────────────────────────────────────────────────────────────────────
# AI / OLLAMA CONFIGURATION
# ───────────────────────────────────────────────────────────────────────────────

# Ollama host
OLLAMA_HOST=http://127.0.0.1:11434

# Default model for chat/completions
OLLAMA_MODEL=qwen3.5:latest

# Embedding model for RAG/vector search
EMBEDDING_MODEL=nomic-embed-text:latest

# External AI APIs (optional)
# GEMINI_API_KEY=your_gemini_api_key
# OPENAI_API_KEY=your_openai_api_key

# ───────────────────────────────────────────────────────────────────────────────
# DEPLOYMENT WEBHOOK (optional)
# ───────────────────────────────────────────────────────────────────────────────

# GitHub deploy webhook secret (generate: openssl rand -hex 32)
DEPLOY_SECRET=CHANGE_ME_USE_64_CHARACTER_HEX_STRING

# ───────────────────────────────────────────────────────────────────────────────
# EMAIL CONFIGURATION (optional)
# ───────────────────────────────────────────────────────────────────────────────

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
# EMAIL_FROM=noreply@cortexbuildpro.com
